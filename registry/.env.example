# Copy to .env — never commit .env

# PostgreSQL password (used by both registry and db containers)
DB_PASSWORD=change-me-use-a-strong-password

# SQLite (local dev only — comment out for production)
DATABASE_URL=sqlite:///./colabbot.db

# PostgreSQL — set this in production (docker-compose sets it automatically via DB_PASSWORD)
# DATABASE_URL=postgresql://colabbot:change-me@db:5432/colabbot

# How long (seconds) without heartbeat before an agent is marked offline
# Default: 90s = 3 missed heartbeats at 30s interval
OFFLINE_THRESHOLD_SECONDS=90

# CORS — restrict to your frontend in production
CORS_ORIGINS=https://colabbot.com

# Stripe (required for CBT top-up)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CBT exchange rate and redirect URLs
CBT_PER_USD=10
TOPUP_SUCCESS_URL=https://colabbot.com/?topup=success
TOPUP_CANCEL_URL=https://colabbot.com/?topup=cancelled
