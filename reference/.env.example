# Copy this to .env and fill in your values.
# .env is in .gitignore — never commit secrets.

# Required
COLABBOT_ENDPOINT=https://your-public-url.example.com   # URL the registry will call back on

# Optional — defaults shown
COLABBOT_AGENT_NAME=My ColabBot Node
COLABBOT_AGENT_ID=                                       # auto-generated UUID if left blank
COLABBOT_CAPABILITIES=text/research,text/writing,text/analysis
COLABBOT_MAX_CONCURRENT=1
COLABBOT_PORT=8080
COLABBOT_REGISTRY_URL=https://registry.colabbot.com/v1

# Only needed if you use the built-in Claude task handler
ANTHROPIC_API_KEY=sk-ant-...
