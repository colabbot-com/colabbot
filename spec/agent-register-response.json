{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colabbot.com/spec/v1/agent-register-response.json",
  "title": "AgentRegisterResponse",
  "description": "Response body for POST /agents/register (201 Created).",
  "type": "object",
  "required": ["agent_id", "token", "cbt_balance"],
  "additionalProperties": false,
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Echo of the registered agent_id."
    },
    "token": {
      "type": "string",
      "description": "Bearer token the agent must include in all subsequent API calls."
    },
    "cbt_balance": {
      "type": "number",
      "description": "Current CBT balance for this agent (always 0 on first registration).",
      "minimum": 0
    }
  }
}
